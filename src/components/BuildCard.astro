---
import type { GalleryEntry } from '../lib/filters';
import { ALL_CATEGORIES, DLCS, labelOf } from '../site-config';
import { withBase } from '../lib/url';

interface Props { entry: GalleryEntry; }
const { entry } = Astro.props;

const thumb = entry.thumbnail || entry.screenshots[0];
const thumbUrl = withBase(`/entry-assets/${entry.id}/${thumb}`);
const detailUrl = withBase(`/entry/${entry.id}/`);
const categoryLabel = labelOf(ALL_CATEGORIES, entry.category);
const objCount = entry.objectCount.toLocaleString();
const dlcLabels = entry.dlc.map(slug => DLCS.find(d => d.slug === slug)).filter(Boolean) as { slug: string; label: string; fullName: string }[];
---

<a class="card" href={detailUrl} data-featured={entry.featured ? 'true' : 'false'}>
  <div class="card__thumb">
    <img src={thumbUrl} alt={`${entry.title} screenshot`} loading="lazy" />
    <span class="card__tier" aria-label={`Tier ${entry.tier}`}>{entry.tier}</span>
    {dlcLabels.length > 0 && (
      <div class="card__dlc" aria-label="Pieces from">
        {dlcLabels.map(d => (
          <span class="card__dlc-glyph" title={d.fullName}>{d.label[0]}</span>
        ))}
      </div>
    )}
    <span class="card__category">{categoryLabel}</span>
    <div class="card__hover">{entry.summary}</div>
  </div>
  <div class="card__body">
    <h3 class="card__title">{entry.title}</h3>
    <div class="card__meta">
      <span>{entry.author.name}</span>
      <span class="card__objects">{objCount} objects</span>
    </div>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius);
    overflow: hidden;
    color: inherit;
    transition: transform 120ms ease, border-color 120ms ease, box-shadow 200ms ease;
    box-shadow: var(--shadow-card);
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent-dim);
    box-shadow: var(--shadow-card-hover);
  }
  .card[data-featured='true'] {
    border-left: 2px solid var(--color-accent);
  }

  .card__thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--color-surface-3);
    overflow: hidden;
  }
  .card__thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }
  .card:hover .card__thumb img { transform: scale(1.03); }

  .card__tier {
    position: absolute;
    top: var(--space-2);
    left: var(--space-2);
    font-family: var(--font-display);
    font-size: 0.75rem;
    background: rgba(12, 10, 9, 0.75);
    color: var(--color-accent);
    border: 1px solid var(--color-accent-dim);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
  }

  .card__dlc {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    display: flex;
    gap: 2px;
  }
  .card__dlc-glyph {
    width: 20px; height: 20px;
    display: inline-flex;
    align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 0.7rem;
    background: rgba(12, 10, 9, 0.75);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    cursor: help;
  }

  .card__category {
    position: absolute;
    bottom: var(--space-2);
    left: var(--space-2);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: rgba(12, 10, 9, 0.85);
    color: var(--color-text-soft);
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
  }

  .card__hover {
    position: absolute;
    inset: auto 0 0 0;
    padding: var(--space-4);
    background: linear-gradient(to top, rgba(12, 10, 9, 0.95), rgba(12, 10, 9, 0));
    color: var(--color-text);
    font-size: 0.85rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 200ms ease, transform 200ms ease;
    pointer-events: none;
  }
  .card:hover .card__hover { opacity: 1; transform: translateY(0); }

  .card__body {
    padding: var(--space-3) var(--space-4) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .card__title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    margin: 0;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .card__meta {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .card__objects { color: var(--color-text-soft); }
</style>
