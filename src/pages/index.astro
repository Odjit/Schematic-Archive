---
import BaseLayout from '../layouts/BaseLayout.astro';
import BuildCard from '../components/BuildCard.astro';
import { CATEGORIES } from '../site-config';
import { withBase } from '../lib/url';
import index from '../data/gallery-index.json';
import { applySort, type GalleryEntry } from '../lib/filters';

const all = index as unknown as GalleryEntry[];
const featured = applySort(all.filter(e => e.featured), 'newest').slice(0, 3);
const latest = applySort(all, 'newest').slice(0, 6);

// Quick-link categories. Show those that actually have entries first.
const categoryCounts = new Map<string, number>();
for (const e of all) categoryCounts.set(e.category, (categoryCounts.get(e.category) ?? 0) + 1);
const quickLinks = CATEGORIES
  .map(c => ({ ...c, count: categoryCounts.get(c.slug) ?? 0 }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 6);

const heroBanner = withBase('/banner-hero.png');
---

<BaseLayout activePage="home">
  <section class="hero" style={`background-image: url(${heroBanner});`}>
    <div class="hero__veil" aria-hidden="true"></div>
    <div class="container">
      <div class="hero__inner">
        <p class="eyebrow">The Schematic Archive</p>
        <h1>Community castle blueprints for V Rising.</h1>
        <p class="hero__sub">
          Browse player-built castles, outposts, raid bases, and showcase builds.
          Download a schematic file, then import it in-game with the
          <a href="https://github.com/Odjit/KindredSchematics">KindredSchematics</a> mod.
        </p>
        <div class="hero__cta">
          <a href={withBase('/browse')} class="btn primary">Browse the archive</a>
          <a href={withBase('/submit')} class="btn">Submit an entry</a>
        </div>
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="section container">
      <header class="section__head">
        <h2 class="section-title">Featured</h2>
        <a href={withBase('/browse?tab=featured')} class="muted">See all featured →</a>
      </header>
      <div class="grid grid--3">
        {featured.map(e => <BuildCard entry={e} />)}
      </div>
    </section>
  )}

  <section class="section container">
    <header class="section__head">
      <h2 class="section-title">Latest entries</h2>
      <a href={withBase('/browse?tab=recent')} class="muted">See all recent →</a>
    </header>
    <div class="grid grid--3">
      {latest.map(e => <BuildCard entry={e} />)}
    </div>
  </section>

  {quickLinks.length > 0 && (
    <section class="section container">
      <header class="section__head"><h2 class="section-title">Browse by category</h2></header>
      <div class="quicklinks">
        {quickLinks.map(c => (
          <a class="quicklink" href={withBase(`/browse?cat=${c.slug}`)}>
            <span class="quicklink__label">{c.label}</span>
            <span class="quicklink__count">{c.count}</span>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* Hero band carries the banner art. On wide screens the full ornamental
     frame plus the castle sits to the right. On narrow screens the image
     scales and the focus stays on the right side (castle), with the wordmark
     reading over the darkened left half. */
  .hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(360px, 52vw, 560px);
    background-color: var(--color-bg);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center right;
    border-bottom: 1px solid var(--color-border-soft);
    overflow: hidden;
  }
  /* Left-to-right dark veil so the wordmark always has contrast regardless
     of how the banner crops on a given viewport. */
  .hero__veil {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      linear-gradient(
        to right,
        var(--color-bg) 0%,
        rgba(10, 12, 20, 0.85) 30%,
        rgba(10, 12, 20, 0.35) 60%,
        transparent 85%
      );
  }
  .hero .container {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    min-height: inherit;
    padding-top: var(--space-7);
    padding-bottom: var(--space-7);
  }
  .hero__inner { max-width: 560px; }
  .hero h1 {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.05;
    margin-bottom: var(--space-4);
  }
  .hero__sub {
    font-size: 1.05rem;
    color: var(--color-text-soft);
    margin-bottom: var(--space-6);
    max-width: 52ch;
  }
  .hero__cta { display: flex; gap: var(--space-3); flex-wrap: wrap; }

  @media (max-width: 720px) {
    /* On mobile the gold frame edges crop off the screen; the castle stays
       partially visible as a backdrop while the wordmark dominates. */
    .hero { background-position: 75% center; }
    .hero__veil {
      background: linear-gradient(
        to bottom,
        rgba(10, 12, 20, 0.55) 0%,
        rgba(10, 12, 20, 0.85) 100%
      );
    }
  }

  .section { margin-top: var(--space-7); }
  .section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-5);
  }
  .grid { display: grid; gap: var(--space-5); }
  .grid--3 { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }

  .quicklinks {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  }
  .quicklink {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius);
    color: var(--color-text);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    transition: border-color 120ms ease, transform 120ms ease;
  }
  .quicklink:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .quicklink__count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
