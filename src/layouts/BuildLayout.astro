---
import BaseLayout from './BaseLayout.astro';
import type { GalleryEntry } from '../lib/filters';

interface Props {
  entry: GalleryEntry;
}

const { entry } = Astro.props;
const thumb = entry.thumbnail || entry.screenshots[0];
---

<BaseLayout
  title={entry.title}
  description={entry.summary}
  ogImage={`/builds/${entry.id}/${thumb}`}
>
  <slot />
</BaseLayout>
