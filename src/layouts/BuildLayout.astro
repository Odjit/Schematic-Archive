---
import BaseLayout from './BaseLayout.astro';
import type { GalleryEntry } from '../lib/filters';

interface Props {
  entry: GalleryEntry;
}

const { entry } = Astro.props;
const thumb = entry.thumbnail || entry.screenshots[0];
// BaseLayout's ogImage prop is passed through withBase() before becoming
// a full URL, so we pass the raw absolute path here.
---

<BaseLayout
  title={entry.title}
  description={entry.summary}
  ogImage={`/entry-assets/${entry.id}/${thumb}`}
>
  <slot />
</BaseLayout>
