{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schematic-archive.example/schemas/manifest.schema.json",
  "title": "Schematic Archive Entry Manifest",
  "type": "object",
  "required": [
    "id",
    "title",
    "summary",
    "author",
    "category",
    "tier",
    "footprint",
    "modes",
    "dlc",
    "themes",
    "objectCount",
    "gameVersion",
    "modVersion",
    "schematicFile",
    "screenshots",
    "submittedAt"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "URL-safe slug. Must match the folder name."
    },
    "title": { "type": "string", "minLength": 2, "maxLength": 80 },
    "summary": { "type": "string", "minLength": 10, "maxLength": 200 },
    "author": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 60 },
        "discord": { "type": "string", "maxLength": 60 },
        "github": { "type": "string", "maxLength": 60 }
      }
    },
    "category": {
      "type": "string",
      "enum": [
        "main-base",
        "outpost",
        "raid-base",
        "pvp-defense",
        "vault",
        "trader-hub",
        "garden",
        "crafting-hall",
        "prison",
        "boss-arena",
        "showcase",
        "roleplay-town"
      ]
    },
    "tier": {
      "type": "string",
      "enum": ["T1", "T2", "T3"]
    },
    "footprint": {
      "type": "string",
      "enum": ["small", "medium", "large", "max"]
    },
    "modes": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["pve", "pvp", "solo", "duo", "trio", "clan"]
      }
    },
    "dlc": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "eldest-bloodline",
          "castlevania",
          "draculas-relics",
          "sinister-evolution",
          "haunted-nights",
          "eternal-dominance"
        ]
      }
    },
    "themes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "gothic",
          "cathedral",
          "ruin",
          "winter",
          "garden",
          "symmetrical",
          "minimalist",
          "maze",
          "throne-room",
          "library",
          "workshop",
          "dungeon"
        ]
      }
    },
    "objectCount": { "type": "integer", "minimum": 1 },
    "gameVersion": {
      "type": "string",
      "enum": ["1.0", "1.1"],
      "description": "Game major version. Add new values as new V Rising versions ship."
    },
    "modVersion": {
      "type": "string",
      "description": "SemVer range string for KindredSchematics, e.g. '>=2.4.0'."
    },
    "schematicFile": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.\\-]+\\.schematic$"
    },
    "thumbnail": {
      "type": "string",
      "description": "Optional. Defaults to screenshots[0]."
    },
    "screenshots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^screenshots/.+\\.(png|jpg|jpeg|webp|svg)$"
      }
    },
    "submittedAt": { "type": "string", "format": "date" },
    "updatedAt": { "type": "string", "format": "date" },
    "featured": { "type": "boolean", "default": false },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "maxLength": 30, "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
      "description": "Freeform low-priority tags. Not used for filter UI."
    },
    "warnings": { "type": "string", "maxLength": 600 }
  }
}
